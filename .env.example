# انسخ هذا الملف إلى .env وعبّئ المفاتيح — لا تضع مفاتيح حقيقية هنا
# مفاتيح VITE_ تُضمَّن في الواجهة (متصفح) — للخدمات المجانية فقط
VITE_FINNHUB_API_KEY=
VITE_HALALTERMINAL_API_KEY=
VITE_FMP_API_KEY=
# مفتاح Anthropic يبقى server-side فقط (بدون VITE_!) — محلياً هنا، وفي Vercel env عند النشر
ANTHROPIC_API_KEY=
# اختياري: تغيير نموذج التحليل (الافتراضي claude-opus-4-8)
ANALYZE_MODEL=
